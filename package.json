{
  "name": "telegram-bot-observer",
  "version": "1.0.0",
  "description": "Telegram user-session observer for keyword-triggered alerts",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/index.ts",
    "session:init": "tsx src/session-init.ts",
    "dialogs:list": "tsx src/list-dialogs.ts"
  },
  "keywords": [
    "telegram",
    "gramjs",
    "observer"
  ],
  "license": "ISC",
  "dependencies": {
